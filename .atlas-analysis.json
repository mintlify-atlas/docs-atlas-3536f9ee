  "keyFeatures": [
    "Seamless integration with Better Auth",
    "Global authentication guard with route-level overrides",
    "Role-based access control (RBAC) for system and organization levels",
    "Permission-based access control for fine-grained authorization",
    "Support for Express and Fastify adapters",
    "WebSocket and GraphQL authentication support",
    "Custom hooks with dependency injection",
    "Automatic body parser configuration",
    "Built-in CORS handling for trusted origins",
    "TypeScript-first with full type safety"
  ],
  "publicApiSurface": [
